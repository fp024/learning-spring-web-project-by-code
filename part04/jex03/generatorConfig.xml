<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
    PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
    "https://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<generatorConfiguration>
  <!-- MyBatis Dynamic SQL LibraryлҘј мӮ¬мҡ©. XMLл§ӨнҚјлҠ” мғқм„ұн•ҳм§Җ м•ҠмқҢ. -->
  <!-- м°ёмЎ°: https://mybatis.org/generator/quickstart.html -->
  <context id="MyBatis3DynamicSqlTest" targetRuntime="MyBatis3DynamicSql">
    <property name="javaFileEncoding" value="UTF-8"/>

    <!-- https://mybatis.org/generator/reference/plugins.html -->
    <plugin type="org.mybatis.generator.plugins.ToStringPlugin"/>

    <!-- мһҗлҸҷмғқм„ұ мЈјм„қ кёҲм§Җ -->
    <commentGenerator>
      <property name="suppressAllComments" value="true"/>
      <property name="useLegacyGeneratedAnnotation" value="true"/>
    </commentGenerator>

    <jdbcConnection
        connectionURL="jdbc:oracle:thin:@localvmdb.oracle_xe_18c:1521:XE"
        driverClass="oracle.jdbc.OracleDriver"
        password="book_ex"
        userId="book_ex"
    />

    <!-- Java лҸ„л©”мқё лӘЁлҚё мғқм„ұ -->
    <javaModelGenerator
        targetPackage="org.fp024.domain"
        targetProject="src/main/java"> <!-- eclipseмқҳ generatorм—җм„ңлҠ” н”„лЎңм қнҠё нҸҙлҚ”лӘ…л¶Җн„° мӢңмһ‘н•ҙм•јн•ҳм§Җл§Ң, Maven н”Ңлҹ¬к·ёмқёмңјлЎң мӢӨн–үмӢңлҠ” srcл¶Җн„° мӢңмһ‘н•ңлӢӨ. -->
      <property name="enableSubPackages" value="true"/>
      <property name="trimStrings" value="true"/>
    </javaModelGenerator>

    <!-- л©”нҚј мқён„°нҺҳмқҙмҠӨ (л ҲнҢҢм§ҖнҶ лҰ¬ мқён„°нҺҳмқҙмҠӨ ) -->
    <javaClientGenerator
        targetPackage="org.fp024.mapper"
        targetProject="src/main/java">
      <property name="enableSubPackages" value="true"/>
    </javaClientGenerator>


    <!-- нғҖмј“ н…Ңмқҙлё” - кІҢмӢңнҢҗ н…Ңмқҙлё” -->
    <table tableName="tbl_board" domainObjectName="BoardVO"
           mapperName="BoardMapper">
      <!-- нӮӨмғқм„ұ м»¬лҹјкіј мҝјлҰ¬лҘј м •мқҳн•ңлӢӨ. -->
      <!-- мӢңнҖҖмҠӨлҘј нҳём¶ңн•ҙм„ң к°’мқ„ л„Јкё° л•Ңл¬ём—җ, identityлҘј falseлЎң л‘”лӢӨ. MySQL AutoIncreatementмҳҖлӢӨл©ҙ trueлЎң л‘җкі , sqlStatemen="MySql" лЎң м„Өм •н•  н•„мҡ”к°Җ мһҲлӢӨ. -->
      <generatedKey column="bno" identity="false" sqlStatement="SELECT seq_board.nextval FROM DUAL"/>

      <!-- Oracleм—җм„ң bno м»¬лҹјмқ„ NUMBER(10,0)мңјлЎң м„Өм •н–ҲлҠ”лҚ°, мқјлӢЁмқҖ BIGINTлЎң мҚЁліёлӢӨ. -->
      <columnOverride column="bno" property="bno" jdbcType='BIGINT' javaType='java.lang.Long'/>
      <columnOverride column="regdate" property="regdate" jdbcType='DATE' javaType='java.time.LocalDateTime'/>
      <columnOverride column="updatedate" property="updateDate" jdbcType='DATE' javaType='java.time.LocalDateTime'/>
      <!-- лҢ“кёҖ мҲҳлҠ” нҳ„мһ¬ мҳҲм ңм—җм„ңлҠ” мӮ¬мҡ©н•ҳм§Җ м•ҠмқҢ -->
      <ignoreColumn column="replycnt"/>
    </table>

    <!-- нғҖмј“ н…Ңмқҙлё” - лҢ“кёҖ н…Ңмқҙлё” -->
    <table tableName="tbl_reply" domainObjectName="ReplyVO"
           mapperName="ReplyMapper">
      <!-- нӮӨмғқм„ұ м»¬лҹјкіј мҝјлҰ¬лҘј м •мқҳн•ңлӢӨ. -->
      <!-- мӢңнҖҖмҠӨлҘј нҳём¶ңн•ҙм„ң к°’мқ„ л„Јкё° л•Ңл¬ём—җ, identityлҘј falseлЎң л‘”лӢӨ.
           MySQL AutoIncrementмҳҖлӢӨл©ҙ trueлЎң л‘җкі , sqlStatemen="MySql" лЎң м„Өм •н•  н•„мҡ”к°Җ мһҲлӢӨ. -->
      <generatedKey column="rno" identity="false" sqlStatement="SELECT seq_reply.nextval FROM DUAL"/>

      <!-- Oracleм—җм„ң bno м»¬лҹјмқ„ NUMBER(10,0)мңјлЎң м„Өм •н–ҲлҠ”лҚ°, мқјлӢЁмқҖ BIGINTлЎң мҚЁліёлӢӨ. -->
      <columnOverride column="rno" property="rno" jdbcType='BIGINT' javaType='java.lang.Long'/>
      <columnOverride column="replydate" property="replyDate" jdbcType='DATE' javaType='java.time.LocalDateTime'/>
      <columnOverride column="updatedate" property="updateDate" jdbcType='DATE' javaType='java.time.LocalDateTime'/>
    </table>

  </context>
</generatorConfiguration>